---
import { site } from "../data/site";
const year = new Date().getFullYear();
---
<footer class="mt-24 bg-white border-t border-[var(--color-line)]">
  <div class="container-page py-14 grid grid-cols-1 md:grid-cols-4 gap-10">
    <div class="md:col-span-2">
      <a href="/" class="inline-block mb-4" aria-label={`${site.name} home`}>
        <img src="/logo.jpg" alt={site.name} class="h-12 w-auto" />
      </a>
      <p class="text-sm text-muted max-w-md leading-relaxed">
        {site.name} is a registered charitable trust (Reg. No. {site.registration}). Every rupee you donate reaches the cause — we run on 0% administrative expenses.
      </p>
      <p class="mt-4 text-sm text-muted">
        <a href={`mailto:${site.email}`} class="hover:text-accent-600 underline-offset-4 hover:underline">{site.email}</a>
      </p>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-ink mb-3 font-sans uppercase tracking-wider">Explore</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/who-we-are/" class="hover:text-accent-600">Who We Are</a></li>
        <li><a href="/how-we-work/" class="hover:text-accent-600">How We Work</a></li>
        <li><a href="/current-causes/" class="hover:text-accent-600">Current Causes</a></li>
        <li><a href="/success-stories/" class="hover:text-accent-600">Success Stories</a></li>
        <li><a href="/refer-a-cause/" class="hover:text-accent-600">Refer a Cause</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-ink mb-3 font-sans uppercase tracking-wider">Trust</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/legal-financial/" class="hover:text-accent-600">Financials</a></li>
        <li><a href="/terms-conditions/" class="hover:text-accent-600">Terms &amp; Conditions</a></li>
        <li><a href="/privacy-policy/" class="hover:text-accent-600">Privacy Policy</a></li>
        <li><a href="/refund-policy/" class="hover:text-accent-600">Refund Policy</a></li>
        <li><a href="/contact-us/" class="hover:text-accent-600">Contact Us</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="container-page py-5 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-muted">
      <p>© {year} {site.name} Trust. Established {site.established}. All rights reserved.</p>
      <p>Donations are eligible for tax exemption under Section 80G.</p>
    </div>
  </div>
</footer>
