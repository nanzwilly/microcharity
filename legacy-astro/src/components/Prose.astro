---
// Typographic wrapper for long-form content pages.
---
<div class="prose-mc">
  <slot />
</div>

<style is:global>
  .prose-mc { color: var(--color-body); font-size: 1.0625rem; line-height: 1.75; max-width: 70ch; }
  .prose-mc h2 { font-family: var(--font-display); color: var(--color-ink); font-size: 1.625rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 1rem; letter-spacing: -0.01em; }
  .prose-mc h3 { font-family: var(--font-display); color: var(--color-ink); font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose-mc p  { margin-bottom: 1.1rem; }
  .prose-mc ul { list-style: disc; padding-left: 1.4rem; margin-bottom: 1.1rem; }
  .prose-mc ol { list-style: decimal; padding-left: 1.4rem; margin-bottom: 1.1rem; }
  .prose-mc li { margin-bottom: 0.4rem; }
  .prose-mc a  { color: var(--color-accent-600); text-decoration: underline; text-underline-offset: 3px; }
  .prose-mc a:hover { color: var(--color-accent-700); }
  .prose-mc strong { color: var(--color-ink); font-weight: 600; }
  .prose-mc hr { border: 0; border-top: 1px solid var(--color-line); margin: 2.5rem 0; }
  .prose-mc blockquote { border-left: 3px solid var(--color-accent-600); padding-left: 1rem; color: var(--color-ink); font-family: var(--font-display); font-style: italic; font-size: 1.25rem; margin: 1.5rem 0; }
</style>
