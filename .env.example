# Public form endpoint (Google Apps Script Web App URL — Refer-a-Cause + Contact submit here)
NEXT_PUBLIC_FORM_ENDPOINT=

# Razorpay (server-side only — keep secret)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Razorpay public key for client SDK
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Gmail SMTP — used for contact form, cause referral, and (later) donation receipt emails.
# Use a Gmail App Password (https://myaccount.google.com/apppasswords). Requires 2-step verification on the Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MicroCharity <info@microcharity.com>"
ADMIN_INBOX=info@microcharity.com

# Database (PostgreSQL)
DATABASE_URL=

# Admin auth
ADMIN_SESSION_SECRET=
