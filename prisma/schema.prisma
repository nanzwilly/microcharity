// MicroCharity database schema
// Aligns with SRS Section 7 — High-Level Data Model.
//
// Run after edits:
//   npx prisma db push   (greenfield / dev)
//   npx prisma migrate dev --name <change>   (once we go to prod migrations)

generator client {
  provider      = "prisma-client-js"
  // Generate binaries for both local dev (native) and the Linux runtime Vercel uses for serverless functions.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CauseStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum DonationType {
  ONLINE
  OFFLINE
  QR
  MANUAL
}

enum DonationStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum UserRole {
  ADMIN
  CONTENT_MANAGER
}

// ---------- Causes (donation pages) ----------

model Cause {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  contentHtml      String        @db.Text
  summary          String?       @db.Text
  featuredImage    String?
  category         String?

  goalAmount       Int           @default(0)
  raisedAmount     Int           @default(0) // denormalised; updated on donation approval
  donorCount       Int           @default(0)

  status           CauseStatus   @default(DRAFT)
  enableOnline     Boolean       @default(true)
  enableOffline    Boolean       @default(true)
  bankInstructions String?       @db.Text
  shareMessage     String?       @db.Text

  metaTitle        String?
  metaDesc         String?

  startDate        DateTime?
  endDate          DateTime?

  // Groups multiple campaigns for the same beneficiary (e.g. quarterly support).
  beneficiaryKey   String?

  // MicroCharity ID — human-readable per-FY identifier shown on cause pages, e.g. MCID-105-24-25.
  // Auto-generated on creation; resets sequence each Indian financial year.
  mcId             String?       @unique
  location         String?       // e.g. "Pala, Kerala"

  donations        Donation[]
  updates          CauseUpdate[]
  announcements    CauseAnnouncement[]

  createdById      String?
  createdBy        User?         @relation(fields: [createdById], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([beneficiaryKey])
}

model CauseUpdate {
  id         String   @id @default(cuid())
  causeId    String
  cause      Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)
  caption    String?
  body       String   @db.Text
  postedAt   DateTime @default(now())
  sortOrder  Int      @default(0)
  // Optional MCID for fund-request-related entries (e.g. fund approvals).
  mcId       String?  @unique

  @@index([causeId])
}

// ---------- Donors ----------

model Donor {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  phone           String?
  address         String?
  panEncrypted    String?    // encrypted at the application layer

  firstDonationAt DateTime?
  lastDonationAt  DateTime?
  totalDonated    Int        @default(0)
  donationCount   Int        @default(0)
  unsubscribed    Boolean    @default(false)

  donations       Donation[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// ---------- Donations ----------

model Donation {
  id                 String         @id @default(cuid())
  causeId            String
  cause              Cause          @relation(fields: [causeId], references: [id])

  donorId            String?
  donor              Donor?         @relation(fields: [donorId], references: [id])

  // Snapshots taken at submission time so future donor profile edits don't rewrite history.
  donorNameSnapshot  String
  donorEmailSnapshot String

  amount             Int
  type               DonationType
  status             DonationStatus @default(PENDING)

  // Razorpay (online) — used as idempotency keys on webhook.
  razorpayOrderId    String?        @unique
  razorpayPaymentId  String?        @unique
  razorpaySignature  String?

  // Offline / manual entries
  paymentReference   String?        // bank transaction ref / cheque #
  utr                String?        // UPI UTR / txn id (QR donations)
  paymentDate        DateTime?      // donor-entered date of payment (offline / QR)
  panEncrypted       String?
  addressSnapshot    String?
  adminNotes         String?

  // Receipt
  receipt            Receipt?

  // Audit
  approvedAt         DateTime?
  approvedById       String?
  approvedBy         User?          @relation(fields: [approvedById], references: [id])

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([causeId, status])
  @@index([donorId])
  @@index([status])
}

// ---------- Receipts ----------

model Receipt {
  id            String    @id @default(cuid())
  receiptNumber String    @unique
  donationId    String    @unique
  donation      Donation  @relation(fields: [donationId], references: [id], onDelete: Cascade)
  pdfUrl        String?
  sentToEmail   String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

model ReceiptTemplate {
  id            String   @id @default(cuid())
  name          String
  htmlContent   String   @db.Text
  isDefault     Boolean  @default(false)
  receiptPrefix String   @default("MCH")
  sequenceStart Int      @default(1)
  logoUrl       String?
  signatureUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------- Users (admin) ----------

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  // Null while a user has been invited but hasn't set a password via the invite link yet.
  passwordHash    String?
  role            UserRole   @default(CONTENT_MANAGER)
  isActive        Boolean    @default(true)
  lastLoginAt     DateTime?

  // One-time invite link. Stores the SHA-256 hash of the token (not the raw token)
  // so a database leak doesn't surrender active invites. The raw token only exists
  // in the email link sent to the invitee. Set on user creation / re-invite; cleared
  // once the user activates by setting their password.
  inviteToken     String?    @unique
  inviteExpiresAt DateTime?

  // Login lockout: tracks failed login bursts per user; cleared on successful login.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  causes              Cause[]
  approvals           Donation[]
  reviewedApplications CauseApplication[]
  announcementsSent   CauseAnnouncement[]

  createdAt       DateTime   @default(now())
}

// ---------- Audit log ----------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // e.g. "donation.approve", "cause.publish"
  entityType String
  entityId   String?
  payload    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}

// ---------- Cause applications (online intake forms) ----------

enum ApplicationFormType {
  EDUCATIONAL
  MEDICAL
  INDIVIDUAL
  ORGANIZATIONAL
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model CauseApplication {
  id            String              @id @default(cuid())
  // Auto-generated, e.g. "MC/EDU/26-27/001". Unique across all FYs.
  applicationNo String              @unique
  formType      ApplicationFormType
  status        ApplicationStatus   @default(SUBMITTED)

  // Mirrored out of `data` so list / search / sort don't need to dig into JSON.
  fullName      String
  phone         String
  email         String?

  // The full submission payload (per-type shape). Validated at submission time;
  // the column itself is opaque so we can evolve form templates without migrations.
  data          Json

  // Filename + size + mime + which slot each attachment came from. The actual file
  // bytes are NEVER persisted — they're forwarded once to info@microcharity.com via
  // email and discarded. This is the metadata so admins know what was sent.
  attachmentMeta Json?

  adminNotes    String?             @db.Text
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?               @relation(fields: [reviewedById], references: [id])

  // Diagnostics for the e-signature acknowledgement.
  submittedFromIp String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([formType])
  @@index([status])
  @@index([createdAt])
}

// ---------- Cause launch announcements (bulk mailers) ----------

enum AnnouncementStatus {
  PENDING    // recipients snapshotted, no batch sent yet
  SENDING    // at least one batch processed
  COMPLETED  // every recipient is SENT or FAILED
  CANCELLED  // admin aborted partway through
}

enum AnnouncementRecipientStatus {
  PENDING
  SENT
  FAILED
}

// One row per "send" of a cause launch email. Admin can re-send a cause (creates a
// new row). totalRecipients is captured at creation time; success/failureCount
// update as each batch finishes.
model CauseAnnouncement {
  id              String                   @id @default(cuid())
  causeId         String
  cause           Cause                    @relation(fields: [causeId], references: [id])

  sentByUserId    String?
  sentBy          User?                    @relation(fields: [sentByUserId], references: [id])

  subject         String

  totalRecipients Int                      @default(0)
  successCount    Int                      @default(0)
  failureCount    Int                      @default(0)

  // True when this was a test send (recipient list is just the sending admin's
  // email instead of every opted-in donor). Kept in history so admins can tell
  // dry-runs apart from the real fires-at-everyone send.
  isTest          Boolean                  @default(false)

  status          AnnouncementStatus       @default(PENDING)

  startedAt       DateTime                 @default(now())
  completedAt     DateTime?

  recipients      AnnouncementRecipient[]

  @@index([causeId])
  @@index([status])
  @@index([startedAt])
}

// One row per (announcement, donor) pair. The recipient list is snapshotted at
// announcement-creation time so that donors who unsubscribe mid-send are still
// processed (they just get SKIPPED at send time, not retroactively removed).
model AnnouncementRecipient {
  id              String                       @id @default(cuid())
  announcementId  String
  announcement    CauseAnnouncement            @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  donorEmail      String
  donorName       String

  status          AnnouncementRecipientStatus  @default(PENDING)
  error           String?
  sentAt          DateTime?

  // Per-recipient HMAC token so the unsubscribe link in one donor's email can't be
  // used to unsubscribe another donor.
  unsubscribeToken String                      @unique

  @@index([announcementId, status])
  @@index([donorEmail])
}

// ---------- Rate limiting ----------
//
// Fixed-window counters keyed by (route, identifier). identifier is typically the
// caller's IP. windowStart is bucket-aligned to the route's window size.
//
// Rows are kept indefinitely (cheap), but a periodic cleanup of buckets older than
// 24h is harmless and easy to add later.

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String   // "route:identifier", e.g. "login:103.21.55.4"
  windowStart DateTime
  count       Int      @default(1)

  @@unique([key, windowStart])
  @@index([windowStart])
}

// ---------- Unsubscribe list ----------

model UnsubscribeList {
  id             String   @id @default(cuid())
  email          String   @unique
  unsubscribedAt DateTime @default(now())
  reason         String?
}
