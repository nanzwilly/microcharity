// MicroCharity database schema
// Aligns with SRS Section 7 — High-Level Data Model.
//
// Run after edits:
//   npx prisma db push   (greenfield / dev)
//   npx prisma migrate dev --name <change>   (once we go to prod migrations)

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CauseStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum DonationType {
  ONLINE
  OFFLINE
  MANUAL
}

enum DonationStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum UserRole {
  ADMIN
  CONTENT_MANAGER
}

// ---------- Causes (donation pages) ----------

model Cause {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  contentHtml      String        @db.Text
  summary          String?       @db.Text
  featuredImage    String?
  category         String?

  goalAmount       Int           @default(0)
  raisedAmount     Int           @default(0) // denormalised; updated on donation approval
  donorCount       Int           @default(0)

  status           CauseStatus   @default(DRAFT)
  enableOnline     Boolean       @default(true)
  enableOffline    Boolean       @default(true)
  bankInstructions String?       @db.Text
  shareMessage     String?       @db.Text

  metaTitle        String?
  metaDesc         String?

  startDate        DateTime?
  endDate          DateTime?

  // Groups multiple campaigns for the same beneficiary (e.g. quarterly support).
  beneficiaryKey   String?

  donations        Donation[]
  updates          CauseUpdate[]

  createdById      String?
  createdBy        User?         @relation(fields: [createdById], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([beneficiaryKey])
}

model CauseUpdate {
  id         String   @id @default(cuid())
  causeId    String
  cause      Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)
  caption    String?
  body       String   @db.Text
  postedAt   DateTime @default(now())
  sortOrder  Int      @default(0)

  @@index([causeId])
}

// ---------- Donors ----------

model Donor {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  phone           String?
  address         String?
  panEncrypted    String?    // encrypted at the application layer

  firstDonationAt DateTime?
  lastDonationAt  DateTime?
  totalDonated    Int        @default(0)
  donationCount   Int        @default(0)
  unsubscribed    Boolean    @default(false)

  donations       Donation[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// ---------- Donations ----------

model Donation {
  id                 String         @id @default(cuid())
  causeId            String
  cause              Cause          @relation(fields: [causeId], references: [id])

  donorId            String?
  donor              Donor?         @relation(fields: [donorId], references: [id])

  // Snapshots taken at submission time so future donor profile edits don't rewrite history.
  donorNameSnapshot  String
  donorEmailSnapshot String

  amount             Int
  type               DonationType
  status             DonationStatus @default(PENDING)

  // Razorpay (online) — used as idempotency keys on webhook.
  razorpayOrderId    String?        @unique
  razorpayPaymentId  String?        @unique
  razorpaySignature  String?

  // Offline / manual entries
  paymentReference   String?
  panEncrypted       String?
  addressSnapshot    String?
  adminNotes         String?

  // Receipt
  receipt            Receipt?

  // Audit
  approvedAt         DateTime?
  approvedById       String?
  approvedBy         User?          @relation(fields: [approvedById], references: [id])

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([causeId, status])
  @@index([donorId])
  @@index([status])
}

// ---------- Receipts ----------

model Receipt {
  id            String    @id @default(cuid())
  receiptNumber String    @unique
  donationId    String    @unique
  donation      Donation  @relation(fields: [donationId], references: [id], onDelete: Cascade)
  pdfUrl        String?
  sentToEmail   String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

model ReceiptTemplate {
  id            String   @id @default(cuid())
  name          String
  htmlContent   String   @db.Text
  isDefault     Boolean  @default(false)
  receiptPrefix String   @default("MCH")
  sequenceStart Int      @default(1)
  logoUrl       String?
  signatureUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------- Users (admin) ----------

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CONTENT_MANAGER)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?

  causes       Cause[]
  approvals    Donation[]

  createdAt    DateTime   @default(now())
}

// ---------- Audit log ----------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // e.g. "donation.approve", "cause.publish"
  entityType String
  entityId   String?
  payload    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
}

// ---------- Unsubscribe list ----------

model UnsubscribeList {
  id             String   @id @default(cuid())
  email          String   @unique
  unsubscribedAt DateTime @default(now())
  reason         String?
}
